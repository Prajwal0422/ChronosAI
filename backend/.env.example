APP_NAME=AI Timetable Generator
DEBUG=false
API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/timetable_db
JWT_SECRET_KEY=change-this-to-a-secure-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
CORS_ORIGINS=["http://localhost:3000"]
AI_GENERATION_TIMEOUT_SECONDS=300
AI_MAX_SOLUTIONS=10
AI_POPULATION_SIZE=100
AI_GENERATIONS=50
